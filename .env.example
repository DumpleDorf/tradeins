# App
NEXT_PUBLIC_APP_URL=https://teslatradeins.com.au
NEXT_PUBLIC_APP_NAME="Tesla Certified Trade-In Wholesale Portal"

# Database (Supabase or Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/tesla_wholesale?schema=public"

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET="your-auth-secret-here"

# Resend (transactional email)
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Tesla Trade-Ins <noreply@teslatradeins.com.au>"
TESLA_TEAM_EMAIL="tradeins@tesla.com"

# Image storage — Supabase Storage (recommended)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="vehicle-photos"

# Optional: notify all active partners when a listing goes live
NOTIFY_PARTNERS_ON_NEW_LISTING="false"
