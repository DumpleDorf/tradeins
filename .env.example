# App
NEXT_PUBLIC_APP_URL=https://teslatradeins.com.au

# Auth (required for login)
AUTH_SECRET="generate-a-long-random-string"

# Database — auto-set by Vercel Supabase integration
POSTGRES_PRISMA_URL="postgresql://..."
POSTGRES_URL_NON_POOLING="postgresql://..."

# Supabase Storage — auto-set by Vercel Supabase integration
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Vercel Supabase integration may expose this name instead:
SUPABASE_SECRET_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="vehicle-photos"

# Email (optional until Resend is configured)
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Tesla Trade-Ins <noreply@teslatradeins.com.au>"
TESLA_TEAM_EMAIL="tradeins@tesla.com"
